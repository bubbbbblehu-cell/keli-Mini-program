.page-shell {
  min-height: 100vh;
  padding: 36rpx 26rpx 28rpx;
}

.hero-card {
  padding: 34rpx;
  border: 1rpx solid rgba(125, 211, 252, 0.16);
  border-radius: 32rpx;
  background: linear-gradient(160deg, rgba(15, 23, 42, 0.92), rgba(20, 36, 67, 0.92));
  box-shadow: 0 18rpx 60rpx rgba(2, 6, 23, 0.34);
}

.hero-kicker {
  display: block;
  color: #7dd3fc;
  letter-spacing: 6rpx;
  font-size: 20rpx;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 54rpx;
  font-weight: 700;
  color: #ecfeff;
}

.hero-desc {
  display: block;
  margin-top: 16rpx;
  line-height: 1.7;
  font-size: 28rpx;
  color: #b6c6e5;
}

.hero-count {
  display: inline-block;
  margin-top: 22rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(56, 189, 248, 0.16);
  color: #bae6fd;
  font-size: 24rpx;
}

.loading-panel {
  margin-top: 28rpx;
  padding: 80rpx 30rpx;
  text-align: center;
}

.loading-dot {
  width: 24rpx;
  height: 24rpx;
  margin: 0 auto 20rpx;
  border-radius: 50%;
  background: #38bdf8;
  box-shadow: 0 0 0 16rpx rgba(56, 189, 248, 0.14);
}

.loading-text {
  color: #b6c6e5;
  font-size: 28rpx;
}

.city-scroll {
  height: calc(100vh - 360rpx);
  margin-top: 26rpx;
}

.country-block {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(10, 19, 37, 0.74);
  border: 1rpx solid rgba(125, 211, 252, 0.1);
}

.country-head {
  margin-bottom: 20rpx;
}

.country-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e2e8f0;
}

.city-grid {
  display: flex;
  flex-wrap: wrap;
}

.city-card {
  width: calc(50% - 9rpx);
  padding: 24rpx 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(18, 31, 57, 0.96), rgba(12, 22, 39, 0.96));
  border: 1rpx solid rgba(125, 211, 252, 0.12);
  margin-right: 18rpx;
  margin-bottom: 18rpx;
}

.city-card:nth-child(2n) {
  margin-right: 0;
}

.city-name {
  display: block;
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 600;
}

.city-code {
  display: block;
  margin-top: 10rpx;
  color: #7dd3fc;
  font-size: 24rpx;
}
