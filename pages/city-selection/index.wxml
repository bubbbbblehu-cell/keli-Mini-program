<view class="page-shell">
  <view class="hero-card">
    <text class="hero-kicker">SAFE STAY ATLAS</text>
    <text class="hero-title">女性安全地图</text>
    <text class="hero-desc">选择一座城市，快速查看酒店安全评分、热力分布和收藏信息。</text>
    <text class="hero-count">当前可选城市：{{cities.length}}</text>
  </view>

  <view wx:if="{{loading}}" class="loading-panel">
    <view class="loading-dot"></view>
    <text class="loading-text">正在同步城市数据...</text>
  </view>

  <scroll-view wx:else scroll-y class="city-scroll">
    <view wx:for="{{countries}}" wx:key="country" class="country-block">
      <view class="country-head">
        <text class="country-title">{{item.country}}</text>
      </view>

      <view class="city-grid">
        <view
          wx:for="{{item.cities}}"
          wx:key="id"
          class="city-card"
          data-city="{{item}}"
          bindtap="handleCityTap"
        >
          <text class="city-name">{{item.name}}</text>
          <text class="city-code">{{item.code}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
